{
  "expo": {
    "name": "TraderRank Pro",
    "slug": "traderrank-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#121a2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.traderrank.pro",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Upload KYC and document images for payout verification."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#121a2e",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.traderrank.pro",
      "permissions": [
        "READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow TraderRank Pro to access your photos for KYC uploads."
        }
      ],
      "expo-status-bar"
    ],
    "extra": {
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    },
    "owner": "willerbinance"
  }
}
