# Database
DATABASE_URL="postgresql://traderrank:traderrank_secret@localhost:5432/traderrank_pro"

# Neon Data API (PostgREST-compatible REST access)
NEON_DATA_API_URL="https://your-project.apirest.region.aws.neon.tech/neondb/rest/v1"
# JWT bearer token for Data API requests (Neon Auth or external provider)
NEON_DATA_API_JWT=""

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# Frontend (CORS — comma-separated origins allowed)
FRONTEND_URL="http://localhost:3000"
# Local admin panel URL (staff appointment emails link here)
ADMIN_HUB_URL="http://localhost:3099"
# Public site URL for referral links, emails, and marketing (official domain)
PUBLIC_APP_URL="https://thetradeguard.com"
# Public HTTPS base URL for uploads, Signal Hub image_url, and webhooks
API_PUBLIC_URL="https://traders-c53s.onrender.com"
PORT=4000

# NOWPayments
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_PUBLIC_KEY=""
NOWPAYMENTS_IPN_SECRET=""
NOWPAYMENTS_API_URL="https://api.nowpayments.io/v1"
# Mass payout / custody login (account.nowpayments.io — required for admin wallet withdrawals)
NOWPAYMENTS_PAYOUT_EMAIL=""
NOWPAYMENTS_PAYOUT_PASSWORD=""
NOWPAYMENTS_PAYOUT_EMAIL=""
NOWPAYMENTS_PAYOUT_PASSWORD=""

# Blockchain scanners (optional — TRC20 works without a key; BEP20/ERC20 need API keys)
TRONGRID_API_KEY=""
BSCSCAN_API_KEY=""
ETHERSCAN_API_KEY=""

# Admin seed (optional — used by npm run prisma:seed)
ADMIN_EMAIL="admin@traderrank.pro"
ADMIN_PASSWORD="Admin123!ChangeMe"
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o"
OPENAI_API_URL="https://api.openai.com/v1"

# DeepSeek AI (signal validation before MT5 execution)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_API_URL="https://api.deepseek.com/v1"

# AARE Signal Hub (MT5 execution)
SIGNAL_HUB_URL="https://signalhub-10zp.onrender.com"
SIGNAL_HUB_PROVIDER_KEY=""
SIGNAL_HUB_PROVIDER_NAME="TraderRank Pro"
# Fallback when live quote unavailable: "limit" or "stop" only (never market — use Place trade for immediate execution)
SIGNAL_HUB_ORDER_TYPE="limit"
SIGNAL_HUB_LOT_SCALE="1.0"

# MetaAPI (MT account provisioning — list connected broker accounts)
METAAPI_TOKEN=""
METAAPI_PROVISIONING_URL="https://mt-provisioning-api-v1.agiliumtrade.agiliumtrade.ai"
METAAPI_CLIENT_URL=""
METAAPI_DEFAULT_ACCOUNT_ID=""
METAAPI_COPY_ACCOUNT_ID=""
METAAPI_TRADE_VOLUME="0.01"

# Webhook secret for POST /api/v1/signals/webhook/outcome (TP/SL notifications)
TRADE_OUTCOME_WEBHOOK_SECRET=""

# Third-party setup feed (GET /api/v1/feeds/setups) — share only with trusted integrators
SETUP_FEED_API_KEY=""

# Email (Resend) — notifications@thetradeguard.com
RESEND_API_KEY=""
EMAIL_FROM="TraderRank Pro <notifications@thetradeguard.com>"

# AWS S3 Compatible Storage
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"
