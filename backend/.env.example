# Database
DATABASE_URL="postgresql://traderrank:traderrank_secret@localhost:5432/traderrank_pro"

# Neon Data API (PostgREST-compatible REST access)
NEON_DATA_API_URL="https://your-project.apirest.region.aws.neon.tech/neondb/rest/v1"
# JWT bearer token for Data API requests (Neon Auth or external provider)
NEON_DATA_API_JWT=""

# Auth
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# Frontend
FRONTEND_URL="http://localhost:3000"
PORT=4000

# NOWPayments
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_PUBLIC_KEY=""
NOWPAYMENTS_IPN_SECRET=""
NOWPAYMENTS_API_URL="https://api.nowpayments.io/v1"
NOWPAYMENTS_PAYOUT_EMAIL=""
NOWPAYMENTS_PAYOUT_PASSWORD=""

# Admin seed (optional — used by npm run prisma:seed)
ADMIN_EMAIL="admin@traderrank.pro"
ADMIN_PASSWORD="Admin123!ChangeMe"
OPENAI_API_KEY=""
OPENAI_VISION_MODEL="gpt-4o"
OPENAI_API_URL="https://api.openai.com/v1"

# DeepSeek AI (signal validation before MT5 execution)
DEEPSEEK_API_KEY=""
DEEPSEEK_MODEL="deepseek-chat"
DEEPSEEK_API_URL="https://api.deepseek.com/v1"

# AARE Signal Hub (MT5 execution)
SIGNAL_HUB_URL="https://signalhub-10zp.onrender.com"
SIGNAL_HUB_PROVIDER_KEY=""
SIGNAL_HUB_PROVIDER_NAME="TraderRank Pro"
SIGNAL_HUB_ORDER_TYPE="limit"

# AWS S3 Compatible Storage
S3_ENDPOINT=""
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"
