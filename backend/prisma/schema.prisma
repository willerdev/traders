generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PayoutMethod {
  TRC20
  MOBILE_MONEY
}

enum UserRole {
  TRADER
  MODERATOR
  ADMIN
}

enum UserStatus {
  PENDING_VERIFICATION
  PENDING_PAYMENT
  ACTIVE
  SUSPENDED
  BANNED
}

enum RankTier {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  ELITE
}

enum TradeDirection {
  BUY
  SELL
}

enum SignalStatus {
  PENDING
  OPEN
  WON
  LOST
  ARCHIVED
  CANCELLED
  REJECTED_DUPLICATE
}

enum PayoutStatus {
  PENDING
  APPROVED
  PAID
  REJECTED
}

enum PayoutSource {
  WEEKLY
  TP_REWARD
  PROFIT_SHARE
}

enum PaymentStatus {
  PENDING
  CONFIRMED
  FAILED
  EXPIRED
}

enum ViolationType {
  DUPLICATE_SIGNAL
  DUPLICATE_TRADE
  MULTIPLE_ACCOUNTS
  IP_ABUSE
  TRADE_MANIPULATION
  SCREENSHOT_REUSE
}

enum SubscriptionPlan {
  FREE
  PREMIUM
  PRO
}

enum WalletTxType {
  TP_REWARD
  DEPOSIT
  PAYOUT
  ADJUSTMENT
  PROFIT_SHARE
  REFERRAL_REWARD
}

enum KycStatus {
  NOT_STARTED
  PENDING
  APPROVED
  REJECTED
}

enum KycDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENSE
}

enum TpClaimStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

enum TpClaimType {
  FULL_TP
  RR_1_TO_1
}

enum CopyTradeStatus {
  PENDING
  OPEN
  CLOSED
  FAILED
  SKIPPED
}

model User {
  id                String     @id @default(cuid())
  email             String?    @unique
  passwordHash      String?
  googleId          String?    @unique
  walletAddress     String?    @unique
  displayName       String
  avatarUrl         String?
  role              UserRole   @default(TRADER)
  status            UserStatus @default(PENDING_VERIFICATION)
  emailVerified     Boolean    @default(false)
  emailVerifyToken  String?
  registrationPaid    Boolean    @default(false)
  profitShareActive   Boolean    @default(false)
  profitShareEnrolledAt DateTime?
  referralCode        String?    @unique
  referredById        String?
  referralKycRewardedAt  DateTime?
  referralPaidRewardedAt DateTime?
  accessExpiresAt   DateTime?
  termsAcceptedAt   DateTime?
  lastLoginIp       String?
  metaApiAccountId  String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  virtualAccount VirtualAccount?
  signals        Signal[]
  tradeScores    TradeScore[]
  rankings       Ranking[]
  payouts        Payout[]
  subscriptions  Subscription[]
  payments       Payment[]
  violations     Violation[]
  riskFlags      RiskFlag[]
  walletTransactions WalletTransaction[]
  signalDrafts       SignalDraft[]
  profile            UserProfile?
  kyc                KycVerification?
  tpClaims           TpClaim[]
  platformNotifications PlatformNotification[]
  directMessages     DirectMessage[] @relation("MessageThread")
  sentDirectMessages DirectMessage[] @relation("MessageSender")
  messageThreadState MessageThreadState?
  loginOtps          LoginOtp[]
  passwordResets     PasswordReset[]
  custodyDeposits    CustodyDeposit[]
  copyTradesSource   CopyTrade[] @relation("CopyTradeSource")
  marketingEmails    MarketingEmail[]
  referredBy         User?   @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals          User[]  @relation("UserReferrals")

  @@index([status])
  @@index([role])
  @@map("users")
}

model UserProfile {
  id                     String         @id @default(cuid())
  userId                 String         @unique
  firstName              String?
  lastName               String?
  phone                  String?
  dateOfBirth            DateTime?
  country                String?
  state                  String?
  city                   String?
  addressLine1           String?
  addressLine2           String?
  postalCode             String?
  payoutMethod           PayoutMethod?
  trc20Address           String?
  mobileMoneyProvider    String?
  mobileMoneyNumber      String?
  mobileMoneyAccountName String?
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

model LoginOtp {
  id        String    @id @default(cuid())
  userId    String
  email     String
  codeHash  String
  expiresAt DateTime
  attempts  Int       @default(0)
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("login_otps")
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@map("password_resets")
}

model KycVerification {
  id               String           @id @default(cuid())
  userId           String           @unique
  status           KycStatus        @default(NOT_STARTED)
  documentType     KycDocumentType?
  documentNumber   String?
  documentFrontUrl String?
  documentBackUrl  String?
  selfieUrl        String?
  rejectionReason  String?
  submittedAt      DateTime?
  reviewedAt       DateTime?
  pendingUploadFilenames String[] @default([])
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("kyc_verifications")
}

model UploadBlob {
  filename    String   @id
  category    String
  data        Bytes
  contentType String   @map("content_type")
  size        Int
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([category])
  @@map("upload_blobs")
}

model VirtualAccount {
  id                  String   @id @default(cuid())
  userId              String   @unique
  balance             Decimal  @default(1000) @db.Decimal(12, 2)
  tier                RankTier @default(BRONZE)
  riskPercent         Decimal  @default(5) @db.Decimal(5, 2)
  maxRiskPerTrade     Decimal  @default(50) @db.Decimal(12, 2)
  weeklyProfit        Decimal  @default(0) @db.Decimal(12, 2)
  totalProfit         Decimal  @default(0) @db.Decimal(12, 2)
  profitShareBalance  Decimal  @default(0) @db.Decimal(12, 2)
  profitShareEarned   Decimal  @default(0) @db.Decimal(12, 2)
  winRate             Decimal  @default(0) @db.Decimal(5, 2)
  score               Int      @default(0)
  consecutiveWins     Int      @default(0)
  consecutiveLosses   Int      @default(0)
  maxDrawdown         Decimal  @default(0) @db.Decimal(5, 2)
  currentDrawdown     Decimal  @default(0) @db.Decimal(5, 2)
  totalTrades         Int      @default(0)
  winningTrades       Int      @default(0)
  losingTrades        Int      @default(0)
  streakWarningIssued Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("virtual_accounts")
}

model Signal {
  id              String         @id @default(cuid())
  signalId        String         @unique @default(cuid())
  userId          String
  symbol          String
  direction       TradeDirection
  entryMin        Decimal        @db.Decimal(18, 8)
  entryMax        Decimal        @db.Decimal(18, 8)
  stopLoss        Decimal        @db.Decimal(18, 8)
  takeProfit      Decimal        @db.Decimal(18, 8)
  riskRewardRatio Decimal        @db.Decimal(5, 2)
  description     String
  screenshotUrl   String
  screenshotHash  String?
  status          SignalStatus   @default(PENDING)
  submittedAt     DateTime       @default(now())
  resolvedAt      DateTime?
  pnl             Decimal?       @db.Decimal(12, 2)
  pointsAwarded   Int            @default(0)
  hubSenderName   String?
  hubRecordId     String?
  hubOrderNotifiedAt DateTime?
  tp1ClaimNoticeApprovedAt DateTime?
  metaApiAccountId String?
  metaApiOrderId   String?
  metaApiPositionId String?
  metaApiExecutedAt DateTime?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade      Trade?
  tradeScore TradeScore?
  tpClaims   TpClaim[]
  copyTrade  CopyTrade?

  @@index([userId])
  @@index([symbol, direction])
  @@index([submittedAt])
  @@index([status])
  @@map("signals")
}

model SignalDraft {
  id            String          @id @default(cuid())
  userId        String
  symbol        String?
  direction     TradeDirection?
  entryMin      Decimal?        @db.Decimal(18, 8)
  entryMax      Decimal?        @db.Decimal(18, 8)
  stopLoss      Decimal?        @db.Decimal(18, 8)
  takeProfit    Decimal?        @db.Decimal(18, 8)
  description   String?
  screenshotUrl String?
  aiFilled      Boolean         @default(false)
  progress      Int             @default(0)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
  @@map("signal_drafts")
}

model Trade {
  id           String         @id @default(cuid())
  signalId     String         @unique
  userId       String
  symbol       String
  direction    TradeDirection
  entryMin     Decimal        @db.Decimal(18, 8)
  entryMax     Decimal        @db.Decimal(18, 8)
  entryPrice   Decimal?       @db.Decimal(18, 8)
  stopLoss     Decimal        @db.Decimal(18, 8)
  takeProfit   Decimal        @db.Decimal(18, 8)
  exitPrice    Decimal?       @db.Decimal(18, 8)
  pnl          Decimal?       @db.Decimal(12, 2)
  isWin        Boolean?
  activatedAt  DateTime?
  tp1NotifiedAt DateTime?
  tp1BreakevenAt DateTime?
  breakevenPending Boolean @default(false)
  breakevenRetryCount Int @default(0)
  partialClosedAt DateTime?
  partialCloseVolume Decimal? @db.Decimal(18, 8)
  partialCloseProfit Decimal? @db.Decimal(12, 2)
  closedAt     DateTime?
  createdAt    DateTime       @default(now())

  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("trades")
}

model TpClaim {
  id                  String         @id @default(cuid())
  userId              String
  signalId            String
  symbol              String
  direction           TradeDirection
  exitPrice           Decimal        @db.Decimal(18, 8)
  beforeScreenshotUrl String
  afterScreenshotUrl  String
  claimType           TpClaimType    @default(FULL_TP)
  status              TpClaimStatus  @default(PENDING_REVIEW)
  adminNote           String?
  reviewedAt          DateTime?
  reviewedById        String?
  submittedAt         DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  signal Signal  @relation(fields: [signalId], references: [id], onDelete: Cascade)
  payout Payout?

  @@index([userId, status])
  @@index([status, submittedAt])
  @@map("tp_claims")
}

model WalletTransaction {
  id           String       @id @default(cuid())
  userId       String
  amount       Decimal      @db.Decimal(12, 2)
  type         WalletTxType
  referenceId  String?
  description  String
  balanceAfter Decimal?     @db.Decimal(12, 2)
  createdAt    DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@map("wallet_transactions")
}

model TradeScore {
  id               String   @id @default(cuid())
  userId           String
  signalId         String   @unique
  basePoints       Int      @default(0)
  rrBonus          Int      @default(0)
  consistencyBonus Int      @default(0)
  totalPoints      Int      @default(0)
  weekNumber       Int
  year             Int
  createdAt        DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  signal Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([userId, year, weekNumber])
  @@map("trade_scores")
}

model Ranking {
  id            String   @id @default(cuid())
  userId        String
  tier          RankTier @default(BRONZE)
  rank          Int
  score         Int      @default(0)
  profit        Decimal  @default(0) @db.Decimal(12, 2)
  winRate       Decimal  @default(0) @db.Decimal(5, 2)
  drawdown      Decimal  @default(0) @db.Decimal(5, 2)
  consistency   Decimal  @default(0) @db.Decimal(5, 2)
  weekNumber    Int
  year          Int
  calculatedAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, year, weekNumber])
  @@index([year, weekNumber, rank])
  @@map("rankings")
}

model Leaderboard {
  id           String   @id @default(cuid())
  userId       String
  displayName  String
  tier         RankTier
  rank         Int
  score        Int
  profit       Decimal  @db.Decimal(12, 2)
  winRate      Decimal  @db.Decimal(5, 2)
  drawdown     Decimal  @db.Decimal(5, 2)
  consistency  Decimal  @db.Decimal(5, 2)
  weekNumber   Int
  year         Int
  updatedAt    DateTime @updatedAt

  @@unique([userId, year, weekNumber])
  @@index([year, weekNumber, rank])
  @@map("leaderboard")
}

model Payout {
  id              String        @id @default(cuid())
  userId          String
  virtualProfit   Decimal       @db.Decimal(12, 2)
  traderShare     Decimal       @db.Decimal(12, 2)
  platformShare   Decimal       @db.Decimal(12, 2)
  traderPercent   Decimal       @default(40) @db.Decimal(5, 2)
  status          PayoutStatus  @default(PENDING)
  source          PayoutSource  @default(WEEKLY)
  tpClaimId       String?       @unique
  payoutMethod    PayoutMethod?
  weekNumber      Int
  year            Int
  walletAddress   String?
  rewardTier      String?
  requestedAt     DateTime      @default(now())
  processedAt     DateTime?
  notes           String?
  gatewayPayoutId String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tpClaim TpClaim? @relation(fields: [tpClaimId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("payouts")
}

model CustodyDeposit {
  id              String        @id @default(cuid())
  adminId         String
  amount          Decimal       @db.Decimal(18, 8)
  currency        String        @default("USDT")
  network         String
  status          PaymentStatus @default(PENDING)
  gatewayId       String?
  gatewayResponse Json?
  payAddress      String?
  payAmount       Decimal?      @db.Decimal(18, 8)
  txHash          String?
  confirmedAt     DateTime?
  createdAt       DateTime      @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([status])
  @@index([status, payAddress])
  @@map("custody_deposits")
}

model Subscription {
  id        String           @id @default(cuid())
  userId    String
  plan      SubscriptionPlan @default(FREE)
  startsAt  DateTime         @default(now())
  expiresAt DateTime?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("subscriptions")
}

model MarketingEmail {
  id       String   @id @default(cuid())
  userId   String
  email    String
  audience String // "unpaid_registration" | "inactive_trader"
  subject  String
  status   String // "SENT" | "FAILED" | "SKIPPED"
  detail   String?
  sentAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sentAt])
  @@index([sentAt])
  @@map("marketing_emails")
}

model Payment {
  id              String        @id @default(cuid())
  userId          String
  amount          Decimal       @db.Decimal(18, 8)
  currency        String        @default("USDT")
  network         String
  status          PaymentStatus @default(PENDING)
  gatewayId       String?
  gatewayResponse Json?
  txHash          String?
  purpose         String        @default("registration")
  payAddress      String?
  payAmount       Decimal?      @db.Decimal(18, 8)
  createdAt       DateTime      @default(now())
  confirmedAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([status, payAddress])
  @@map("payments")
}

model Violation {
  id          String        @id @default(cuid())
  userId      String
  type        ViolationType
  description String
  evidence    Json?
  resolved    Boolean       @default(false)
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("violations")
}

model RiskFlag {
  id        String   @id @default(cuid())
  userId    String
  reason    String
  severity  Int      @default(1)
  metadata  Json?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("risk_flags")
}

model PlatformConfig {
  id                    String  @id @default("default")
  registrationFeeUsdt   Decimal @default(5) @db.Decimal(10, 2)
  traderPayoutPercent   Decimal @default(40) @db.Decimal(5, 2)
  platformPayoutPercent Decimal @default(60) @db.Decimal(5, 2)
  riskPercent           Decimal @default(5) @db.Decimal(5, 2)
  startingBalance       Decimal @default(1000) @db.Decimal(12, 2)
  winPoints             Int     @default(10)
  lossPoints            Int     @default(-5)
  duplicateThreshold    Decimal @default(0.9) @db.Decimal(3, 2)
  entryTolerancePercent Decimal @default(0.2) @db.Decimal(5, 2)
  tpRewardUsd           Decimal @default(5) @db.Decimal(10, 2)
  profitShareFeeUsdt    Decimal @default(50) @db.Decimal(10, 2)
  profitSharePercent    Decimal @default(50) @db.Decimal(5, 2)
  profitShareWithdrawThresholdPercent Decimal @default(40) @db.Decimal(5, 2)
  requireKycForPayouts  Boolean @default(true)
  referralKycRewardUsdt  Decimal @default(0.5) @db.Decimal(10, 2)
  referralPaidRewardUsdt Decimal @default(1) @db.Decimal(10, 2)

  @@map("platform_config")
}

model PromoCode {
  id              String   @id @default(cuid())
  code            String   @unique
  discountPercent Int
  description     String
  expiresAt       DateTime
  active          Boolean  @default(true)
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([expiresAt])
  @@index([active])
  @@map("promo_codes")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
  @@map("audit_logs")
}

model PlatformNotification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String    @db.Text
  linkUrl   String?
  signalId  String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, createdAt])
  @@map("platform_notifications")
}

model DirectMessage {
  id         String    @id @default(cuid())
  userId     String
  senderId   String
  senderRole UserRole
  body       String    @db.Text
  isAgent    Boolean   @default(false) @map("is_agent")
  readAt     DateTime?
  createdAt  DateTime  @default(now())

  threadUser User @relation("MessageThread", fields: [userId], references: [id], onDelete: Cascade)
  sender     User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("direct_messages")
}

model MessageThreadState {
  userId       String    @id @map("user_id")
  agentEnabled Boolean   @default(true) @map("agent_enabled")
  escalatedAt  DateTime? @map("escalated_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("message_thread_states")
}

model CopyTrade {
  id                String          @id @default(cuid())
  signalId          String          @unique
  sourceUserId      String
  sourceRank        Int
  copyAccountId     String
  symbol            String
  direction         TradeDirection
  volume            Decimal?        @db.Decimal(18, 8)
  entryPrice        Decimal?        @db.Decimal(18, 8)
  stopLoss          Decimal         @db.Decimal(18, 8)
  takeProfit        Decimal         @db.Decimal(18, 8)
  metaApiOrderId    String?
  metaApiPositionId String?
  status            CopyTradeStatus @default(PENDING)
  profit            Decimal?        @db.Decimal(12, 2)
  commissionCredited Boolean        @default(false)
  notes             String?
  executedAt        DateTime?
  closedAt          DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  signal     Signal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  sourceUser User   @relation("CopyTradeSource", fields: [sourceUserId], references: [id], onDelete: Cascade)

  @@index([sourceUserId])
  @@index([copyAccountId])
  @@index([status])
  @@map("copy_trades")
}
