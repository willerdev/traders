# Same-origin API path — Vite dev server proxies to VITE_PROXY_TARGET (no CORS).
VITE_API_URL=/api/v1
# Production API (emails work here if RESEND is set on Render traders-api):
# VITE_PROXY_TARGET=https://traders-c53s.onrender.com

# Local backend (needs RESEND_API_KEY in backend/.env too):
VITE_PROXY_TARGET=http://localhost:4000
